---
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import Header from "../components/Header.astro";
import SiteHead from "../components/SiteHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname?: string;
  image?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, pathname = "/", image, schema } = Astro.props;

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Imoveis Teresina",
  url: "https://imoveisteresina.netlify.app",
  logo: "https://imoveisteresina.netlify.app/favicon.svg",
  telephone: "+55 86 99925-4624",
  areaServed: "Teresina, PI",
  sameAs: [
    "https://imoveisteresina.netlify.app",
  ],
};

const mergedSchema = schema ? [baseSchema, ...(Array.isArray(schema) ? schema : [schema])] : baseSchema;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <SiteHead
      title={title}
      description={description}
      pathname={pathname}
      image={image}
      schema={mergedSchema}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>
