---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Início" },
  { href: "/imoveis/", label: "Imóveis" },
  { href: "/contato/", label: "Contato" },
];
---

<header class="site-header">
  <div class="container topbar">
    <a class="brand" href="/">
      <span class="brand-mark">IT</span>
      <span>
        <strong>Imóveis Teresina</strong>
      </span>
    </a>

    <nav aria-label="Principal" class="main-nav">
      {navItems.map((item) => (
        <a class={currentPath === item.href ? "active" : ""} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <a
      class="button button-primary header-cta"
      href="https://wa.me/5586999254624?text=Ol%C3%A1%2C%20quero%20mais%20informa%C3%A7%C3%B5es%20sobre%20os%20im%C3%B3veis."
      target="_blank"
      rel="noreferrer"
    >
      Falar no WhatsApp
    </a>
  </div>
</header>
