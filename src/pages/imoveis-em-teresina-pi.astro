---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PropertyCard from "../components/PropertyCard.astro";

const imoveis = (await getCollection("imoveis")).slice(0, 2);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Imoveis em Teresina-PI",
    url: "https://imoveisteresina.netlify.app/imoveis-em-teresina-pi/",
    description:
      "Anuncios de imoveis em Teresina-PI com contato rapido e informacoes objetivas.",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Como encontrar imoveis em Teresina-PI com mais rapidez?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Priorize paginas com URL propria para cada anuncio, informacoes locais claras e contato direto por WhatsApp.",
        },
      },
      {
        "@type": "Question",
        name: "Como falar com o vendedor?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Cada anuncio traz telefone e botao de WhatsApp para agilizar o atendimento.",
        },
      },
    ],
  },
];
---

<BaseLayout
  title="Imoveis em Teresina-PI | Anuncios e oportunidades"
  description="Veja anuncios de imoveis em Teresina-PI com fotos, localizacao de referencia e contato direto pelo WhatsApp."
  pathname="/imoveis-em-teresina-pi/"
  image="/uploads/imoveis/memorare/1.jpg"
  schema={schema}
>
  <div class="container breadcrumb">
    <a href="/">Inicio</a>
    <span>/</span>
    <span>Imoveis em Teresina-PI</span>
  </div>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Teresina-PI</span>
      <h1>Imoveis em Teresina-PI</h1>
      <p>
        Encontre anuncios com fotos, referencias de localizacao e atendimento
        direto para quem deseja comprar, vender ou saber mais sobre um imovel.
      </p>
    </div>
  </section>

  <section class="section-sm">
    <div class="container grid-2">
      <article class="detail-card prose">
        <h2>Oportunidades para quem busca imovel em Teresina</h2>
        <p>
          Nesta pagina voce encontra anuncios reunidos por cidade, com acesso
          rapido ao catalogo completo, telefones visiveis e botao de WhatsApp
          para falar direto com o vendedor.
        </p>
        <p>
          O objetivo e facilitar a negociacao: o comprador analisa os dados
          principais do anuncio e o vendedor recebe contatos com mais rapidez.
        </p>

        <h2>O que voce encontra aqui</h2>
        <ul>
          <li>anuncios com descricao objetiva</li>
          <li>fotos e referencias de localizacao</li>
          <li>telefone e WhatsApp em destaque</li>
          <li>oportunidades em diferentes regioes de Teresina</li>
          <li>navegacao simples no celular e no computador</li>
        </ul>
      </article>

      <aside class="sidebar-card">
        <h2>Dicas para avaliar um anuncio</h2>
        <ul>
          <li>confira a regiao e os acessos</li>
          <li>observe a vocacao residencial ou comercial</li>
          <li>solicite mais detalhes pelo WhatsApp</li>
          <li>confirme disponibilidade antes da visita</li>
          <li>compare anuncios por localizacao e potencial</li>
        </ul>

        <a class="button button-primary" href="/blog/">
          Ver conteudos
        </a>
      </aside>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <h2>Anuncios em destaque</h2>
      <div class="property-grid" style="margin-top: 1.5rem;">
        {imoveis.map((item) => <PropertyCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
