---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PropertyCard from "../components/PropertyCard.astro";

const imoveis = (await getCollection("imoveis")).slice(0, 2);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Imóveis em Teresina-PI",
    url: "https://imoveisteresina.netlify.app/imoveis-em-teresina-pi/",
    description:
      "Anúncios de imóveis em Teresina-PI com contato rápido e informações objetivas.",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Como encontrar imóveis em Teresina-PI com mais rapidez?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Priorize páginas com URL própria para cada anúncio, informações locais claras e contato direto por WhatsApp.",
        },
      },
      {
        "@type": "Question",
        name: "Como falar comigo sobre um anúncio?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Cada anúncio traz meu telefone e botão de WhatsApp para agilizar o atendimento.",
        },
      },
    ],
  },
];
---

<BaseLayout
  title="Imóveis em Teresina-PI | Anúncios e oportunidades"
  description="Veja anúncios de imóveis em Teresina-PI com fotos, localização de referência e contato direto pelo WhatsApp."
  pathname="/imoveis-em-teresina-pi/"
  image="/uploads/imoveis/memorare/1.jpg"
  schema={schema}
>
  <div class="container breadcrumb">
    <a href="/">Início</a>
    <span>/</span>
    <span>Imóveis em Teresina-PI</span>
  </div>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Teresina-PI</span>
      <h1>Imóveis em Teresina-PI</h1>
      <p>
        Encontre anúncios com fotos, referências de localização e contato direto
        comigo para saber mais sobre cada imóvel.
      </p>
    </div>
  </section>

  <section class="section-sm">
    <div class="container grid-2">
      <article class="detail-card prose">
        <h2>Oportunidades para quem busca imóvel em Teresina</h2>
        <p>
          Nesta página você encontra anúncios reunidos por cidade, com acesso
          rápido ao catálogo completo, telefones visíveis e botão de WhatsApp
          para falar direto comigo.
        </p>
        <p>
          O objetivo é facilitar a negociação: o comprador analisa os dados
          principais do anúncio e entra em contato comigo com mais rapidez.
        </p>

        <h2>O que você encontra aqui</h2>
        <ul>
          <li>anúncios com descrição objetiva</li>
          <li>fotos e referências de localização</li>
          <li>telefone e WhatsApp em destaque</li>
          <li>oportunidades em diferentes regiões de Teresina</li>
          <li>navegação simples no celular e no computador</li>
        </ul>
      </article>

      <aside class="sidebar-card">
        <h2>Dicas para avaliar um anúncio</h2>
        <ul>
          <li>confira a região e os acessos</li>
          <li>observe a vocação residencial ou comercial</li>
          <li>solicite mais detalhes pelo WhatsApp</li>
          <li>confirme disponibilidade antes da visita</li>
          <li>compare anúncios por localização e potencial</li>
        </ul>

        <a class="button button-primary" href="/imoveis/">
          Ver anúncios
        </a>
      </aside>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <h2>Anúncios em destaque</h2>
      <div class="property-grid" style="margin-top: 1.5rem;">
        {imoveis.map((item) => <PropertyCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
