---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PropertyCard from "../components/PropertyCard.astro";

const imoveis = (await getCollection("imoveis")).slice(0, 2);

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Imóveis em Teresina-PI",
  url: "https://imoveisteresina.netlify.app/imoveis-em-teresina-pi/",
  description:
    "Veja imóveis em Teresina-PI com fotos, localização de referência e contato direto pelo WhatsApp.",
};
---

<BaseLayout
  title="Imóveis em Teresina-PI | Casas, terrenos e oportunidades"
  description="Veja imóveis em Teresina-PI com fotos, localização de referência, terrenos anunciados e contato direto pelo WhatsApp."
  pathname="/imoveis-em-teresina-pi/"
  image="/uploads/imoveis/memorare/1.jpg"
  schema={schema}
>
  <div class="container breadcrumb">
    <a href="/">Início</a>
    <span>/</span>
    <span>Imóveis em Teresina-PI</span>
  </div>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Teresina-PI</span>
      <h1>Imóveis em Teresina-PI</h1>
      <p>
        Encontre imóveis em Teresina-PI com fotos, referências de localização e
        contato direto comigo para saber mais sobre cada anúncio.
      </p>
    </div>
  </section>

  <section class="section-sm">
    <div class="container grid-2">
      <article class="detail-card prose">
        <h2>Oportunidades para quem busca imóveis em Teresina</h2>
        <p>
          Nesta página você encontra imóveis em Teresina-PI com acesso rápido ao
          catálogo completo, telefones visíveis e botão de WhatsApp para falar
          direto comigo.
        </p>
        <p>
          Os anúncios reúnem terrenos e outras oportunidades em diferentes
          regiões da cidade, facilitando a busca por localização e contato.
        </p>

        <h2>O que você encontra aqui</h2>
        <ul>
          <li>imóveis em Teresina-PI organizados em páginas próprias</li>
          <li>fotos e referências de localização para avaliar cada oportunidade</li>
          <li>telefone e WhatsApp em destaque para atendimento rápido</li>
          <li>terrenos e anúncios em diferentes regiões de Teresina</li>
          <li>navegação simples no celular e no computador</li>
        </ul>
      </article>

      <aside class="sidebar-card">
        <h2>Buscas relacionadas</h2>
        <ul>
          <li><a href="/imoveis/">Catálogo completo de imóveis</a></li>
          <li><a href="/terrenos-em-teresina-pi/">Terrenos em Teresina-PI</a></li>
          <li><a href="/contato/">Contato direto por WhatsApp</a></li>
        </ul>

        <a class="button button-primary" href="/imoveis/">
          Ver anúncios
        </a>
      </aside>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <h2>Anúncios em destaque</h2>
      <div class="property-grid" style="margin-top: 1.5rem;">
        {imoveis.map((item) => <PropertyCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
