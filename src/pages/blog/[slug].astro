---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const artigos = await getCollection("blog");
  return artigos.map((item) => ({
    params: { slug: item.data.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: item.data.title,
  description: item.data.seoDescription,
  datePublished: item.data.publishedAt.toISOString(),
  dateModified: item.data.updatedAt.toISOString(),
  author: {
    "@type": "Organization",
    name: "Imoveis Teresina",
  },
  publisher: {
    "@type": "Organization",
    name: "Imoveis Teresina",
    logo: {
      "@type": "ImageObject",
      url: "https://imoveisteresina.netlify.app/favicon.svg",
    },
  },
  mainEntityOfPage: `https://imoveisteresina.netlify.app/blog/${item.data.slug}/`,
};
---

<BaseLayout
  title={item.data.seoTitle}
  description={item.data.seoDescription}
  pathname={`/blog/${item.data.slug}/`}
  schema={schema}
>
  <div class="container breadcrumb">
    <a href="/">Inicio</a>
    <span>/</span>
    <a href="/blog/">Blog</a>
    <span>/</span>
    <span>{item.data.title}</span>
  </div>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">{item.data.category}</span>
      <h1>{item.data.title}</h1>
      <p>{item.data.description}</p>
      <p style="color: var(--muted);">{item.data.readingTime}</p>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <article class="detail-card prose">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>
