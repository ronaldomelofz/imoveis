---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contato | Imóveis Teresina",
  url: "https://imoveisteresina.netlify.app/contato/",
};
---

<BaseLayout
  title="Contato | Imóveis Teresina"
  description="Entre em contato comigo para pedir mais informações sobre os imóveis anunciados em Teresina-PI."
  pathname="/contato/"
  schema={schema}
>
  <div class="container breadcrumb">
    <a href="/">Início</a>
    <span>/</span>
    <span>Contato</span>
  </div>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Atendimento rápido</span>
      <h1>Fale comigo sobre os imóveis anunciados</h1>
    </div>
  </section>

  <section class="section-sm">
    <div class="container content-grid">
      <article class="detail-card">
        <h2>Enviar mensagem</h2>
        <form
          class="contact-form"
          name="contato"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contato" />
          <p hidden>
            <label>
              Não preencha este campo
              <input name="bot-field" />
            </label>
          </p>

          <div class="field">
            <input type="text" name="nome" placeholder="Seu nome" required />
          </div>
          <div class="field">
            <input type="tel" name="telefone" placeholder="Seu telefone" required />
          </div>
          <div class="field">
            <input type="text" name="assunto" placeholder="Assunto" required />
          </div>
          <div class="field">
            <textarea
              name="mensagem"
              rows="6"
              placeholder="Descreva o imóvel ou a sua necessidade"
              required
            ></textarea>
          </div>
          <button class="button button-primary" type="submit">
            Enviar mensagem
          </button>
        </form>
      </article>

      <aside class="sidebar-card">
        <h2>Atalhos de contato</h2>
        <div class="contact-box">
          <p><strong>WhatsApp:</strong> (86) 99925-4624</p>
          <p><strong>Cidade foco:</strong> Teresina - PI</p>
          <p><strong>Atendimento:</strong> informações, negociação e visitas</p>
        </div>

        <div class="hero-actions" style="margin-top: 1rem;">
          <a
            class="button button-primary"
            href="https://wa.me/5586999254624?text=Ol%C3%A1%2C%20quero%20falar%20sobre%20um%20im%C3%B3vel%20em%20Teresina."
            target="_blank"
            rel="noreferrer"
          >
            Chamar no WhatsApp
          </a>
          <a class="button button-ghost" href="tel:+5586999254624">
            Ligar
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
