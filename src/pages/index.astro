---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PropertyCard from "../components/PropertyCard.astro";

const imoveis = (await getCollection("imoveis")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
const destaques = imoveis.filter((item) => item.data.featured).slice(0, 2);

const homeSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Imoveis Teresina",
    url: "https://imoveisteresina.netlify.app",
    potentialAction: {
      "@type": "SearchAction",
      target: "https://imoveisteresina.netlify.app/imoveis/?busca={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    name: "Imoveis Teresina",
    areaServed: "Teresina, PI",
    telephone: "+55 86 99925-4624",
    url: "https://imoveisteresina.netlify.app",
  },
];
---

<BaseLayout
  title="Imoveis em Teresina-PI | Imoveis Teresina"
  description="Imoveis em Teresina-PI com fotos, descricao, localizacao de referencia e contato direto pelo WhatsApp."
  pathname="/"
  image="/uploads/imoveis/petronio-portela/1.jpg"
  schema={homeSchema}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Anuncios em destaque</span>
        <h1 class="section-title">
          Imoveis em Teresina-PI entre em contato direto pelo WhatsApp.
        </h1>
        <p>
          Veja terrenos e oportunidades em Teresina com fotos, localizacao de
          referencia, descricao objetiva e meu contato em cada anuncio.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href="/imoveis/">
            Ver imoveis
          </a>
          <a
            class="button button-ghost"
            href="https://wa.me/5586999254624?text=Ola%2C%20quero%20mais%20informacoes%20sobre%20os%20imoveis."
            target="_blank"
            rel="noreferrer"
          >
            Falar comigo
          </a>
        </div>

        <div class="hero-stats">
          <div>
            <strong>{imoveis.length}</strong>
            <span>anuncios ativos</span>
          </div>
          <div>
            <strong>Contato</strong>
            <span>direto comigo</span>
          </div>
          <div>
            <strong>Teresina</strong>
            <span>oportunidades por regiao</span>
          </div>
        </div>
      </div>

      <aside class="hero-panel">
        <div class="hero-panel-image">
          <img
            src="/uploads/imoveis/petronio-portela/1.jpg"
            alt="Mapa do terreno em destaque na regiao da Petronio Portela"
            width="768"
            height="520"
          />
        </div>
        <h2>Divulgacao simples e objetiva</h2>
        <p>
          Cada anuncio apresenta os principais detalhes do imovel para facilitar
          a avaliacao e agilizar o atendimento.
        </p>
      </aside>
    </div>
  </section>

  <section class="section-sm home-showcase">
    <div class="container">
      <div class="showcase-head">
        <div>
          <span class="eyebrow">Anuncios</span>
          <h2 class="showcase-title">Imoveis em destaque</h2>
        </div>
        <a class="button button-ghost" href="/imoveis/">
          Ver catalogo completo
        </a>
      </div>

      <div class="property-grid property-grid-compact" style="margin-top: 1.5rem;">
        {destaques.map((item) => <PropertyCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <div class="cta-band home-cta-band">
        <div>
          <span class="eyebrow">Contato direto</span>
          <h2>Quer saber mais sobre um imovel?</h2>
          <p>
            Fale comigo para confirmar disponibilidade, valores e agendar uma
            visita.
          </p>
        </div>

        <div class="hero-actions home-cta-actions">
          <a
            class="button button-primary"
            href="https://wa.me/5586999254624?text=Ola%2C%20quero%20mais%20informacoes%20sobre%20os%20imoveis."
            target="_blank"
            rel="noreferrer"
          >
            Chamar no WhatsApp
          </a>
          <a class="button button-ghost" href="tel:+5586999254624">
            Ligar agora
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
